    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^4.1.9"
