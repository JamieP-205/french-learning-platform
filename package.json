{
  "name": "french-learning-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify:curriculum": "tsx content-tools/verify-curriculum.ts",
    "verify:coverage": "tsx content-tools/verify-coverage.ts",
    "check:copy": "tsx content-tools/check-copy.ts",
    "release:check": "npm run verify:curriculum && npm run verify:coverage && npm run check:copy && npm run lint && npm run typecheck && npm test && npm run build && npm run test:e2e && npm audit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "next": "^16.2.9",
