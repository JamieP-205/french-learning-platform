# Supabase public browser configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fail closed. Set true only after custom SMTP is configured and a fresh
# production account completes the full confirmation-email round trip.
NEXT_PUBLIC_ACCOUNT_SYNC_READY=false

# Server-only. Never expose these values in browser code or commits.
SUPABASE_SERVICE_ROLE_KEY=
# Keep generative explanations off until the tutor evaluation set passes.
ENABLE_GENERATIVE_TUTOR=false
OPENAI_API_KEY=
OPENAI_MODEL_TUTOR=
CRON_SECRET=

# Public application URL, used for auth redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
